    <bpmn:sequenceFlow id="Flow_0wxby26" sourceRef="charge-wait" targetRef="charge-payment" />
    <bpmn:sequenceFlow id="Flow_0a3qg4e" sourceRef="payment-status" targetRef="charge-wait" />
  </bpmn:process>
