    <bpmn:sequenceFlow id="Flow_12rnn5h" sourceRef="charge-payment" targetRef="payment-success" />
    <bpmn:sequenceFlow id="Flow_18ud5gi" sourceRef="payment-success" targetRef="check-status" />
    <bpmn:serviceTask id="charge-payment" name="Charge Payment" camunda:type="external" camunda:topic="order.payment.charge">
