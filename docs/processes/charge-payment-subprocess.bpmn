    <bpmn:sequenceFlow id="Flow_05ucnd3" sourceRef="check-status" targetRef="payment-status" />
    <bpmn:sequenceFlow id="check-payment-status-flow" sourceRef="payment-status" targetRef="Event_0v6t5nz">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isPaymentSuccess}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:intermediateCatchEvent id="charge-wait">
