# === RabbitMQ ===
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# === Process Engine ===
PROCESS_ENGINE_PERSISTENCE_ENABLED=true
PROCESS_ENGINE_RABBITMQ_HOST=rabbitmq
PROCESS_ENGINE_RABBITMQ_PORT=5672
PROCESS_ENGINE_RABBITMQ_USERNAME=guest
PROCESS_ENGINE_RABBITMQ_PASSWORD=guest
PROCESS_ENGINE_RETRY_MAX_ATTEMPTS=3
PROCESS_ENGINE_RETRY_BASE_INTERVAL=5s
PROCESS_ENGINE_RETRY_MAX_INTERVAL=5m

# === Spring ===
SERVER_PORT=8080
SPRING_THREADS_VIRTUAL_ENABLED=true
